{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedx.example/schema/mdp.schema.json",
  "title": "Model Definition Package Schema",
  "description": "Schema for machine-readable embedded AI model definitions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mdp_version",
    "compliance_level",
    "model_id",
    "model_name",
    "model_class",
    "description",
    "interface",
    "behavior",
    "degraded_operation",
    "traceability"
  ],
  "properties": {
    "mdp_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "compliance_level": {
      "type": "string",
      "enum": [
        "Level 1",
        "Level 2"
      ]
    },
    "model_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-.]*$"
    },
    "model_name": {
      "type": "string",
      "minLength": 1
    },
    "model_class": {
      "type": "string",
      "enum": [
        "tracking_prediction",
        "time_series_prediction",
        "anomaly_detection",
        "classification",
        "regression",
        "adaptive_reasoning",
        "hybrid"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "interface": {
      "$ref": "#/$defs/interfaceDefinition"
    },
    "state": {
      "$ref": "#/$defs/stateDefinition"
    },
    "behavior": {
      "$ref": "#/$defs/behaviorDefinition"
    },
    "constraints": {
      "$ref": "#/$defs/constraintsDefinition"
    },
    "degraded_operation": {
      "$ref": "#/$defs/degradedOperationDefinition"
    },
    "artifacts": {
      "$ref": "#/$defs/artifactsDefinition"
    },
    "traceability": {
      "$ref": "#/$defs/traceabilityDefinition"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "compliance_level": {
            "const": "Level 1"
          }
        }
      },
      "then": {
        "required": [
          "mdp_version",
          "compliance_level",
          "model_id",
          "model_name",
          "model_class",
          "description",
          "interface",
          "behavior",
          "degraded_operation",
          "traceability"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "compliance_level": {
            "const": "Level 2"
          }
        }
      },
      "then": {
        "required": [
          "mdp_version",
          "compliance_level",
          "model_id",
          "model_name",
          "model_class",
          "description",
          "interface",
          "behavior",
          "degraded_operation",
          "traceability",
          "constraints"
        ],
        "properties": {
          "degraded_operation": {
            "allOf": [
              {
                "$ref": "#/$defs/degradedOperationDefinition"
              },
              {
                "required": [
                  "minimum_required_inputs",
                  "rules"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "behavior": {
            "properties": {
              "stateful": {
                "const": true
              }
            },
            "required": [
              "stateful"
            ]
          }
        }
      },
      "then": {
        "required": [
          "state"
        ]
      }
    }
  ],
  "$defs": {
    "namedSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "data_type",
        "unit",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "data_type": {
          "type": "string",
          "enum": [
            "bool",
            "int8",
            "uint8",
            "int16",
            "uint16",
            "int32",
            "uint32",
            "int64",
            "uint64",
            "float16",
            "float32",
            "float64"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "default_value": {
          "type": [
            "boolean",
            "integer",
            "number",
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "fallback_policy": {
          "type": "string",
          "enum": [
            "none",
            "derive_from_history",
            "hold_last_value",
            "substitute_default",
            "estimate_from_related_inputs",
            "external_runtime_policy"
          ]
        },
        "degraded_impact": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      }
    },
    "outputSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "data_type",
        "unit"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "data_type": {
          "type": "string",
          "enum": [
            "bool",
            "int8",
            "uint8",
            "int16",
            "uint16",
            "int32",
            "uint32",
            "int64",
            "uint64",
            "float16",
            "float32",
            "float64"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "description": {
          "type": "string"
        },
        "semantic_role": {
          "type": "string"
        }
      }
    },
    "interfaceDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs",
        "outputs"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/namedSignal"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/outputSignal"
          }
        }
      }
    },
    "stateVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "data_type",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "data_type": {
          "type": "string",
          "enum": [
            "bool",
            "int8",
            "uint8",
            "int16",
            "uint16",
            "int32",
            "uint32",
            "int64",
            "uint64",
            "float16",
            "float32",
            "float64"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "retained_between_cycles": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "stateDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stateful": {
          "type": "boolean"
        },
        "variables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateVariable"
          }
        },
        "window_samples": {
          "type": "integer",
          "minimum": 1
        },
        "warmup_cycles": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "behaviorDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_objective",
        "stateful"
      ],
      "properties": {
        "primary_objective": {
          "type": "string",
          "minLength": 1
        },
        "stateful": {
          "type": "boolean"
        },
        "prediction_horizon_ms": {
          "type": "integer",
          "minimum": 0
        },
        "recommended_cycle_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "latency_requirement_ms": {
          "type": "integer",
          "minimum": 0
        },
        "output_semantics": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "constraintsDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "numeric_precision": {
          "type": "string",
          "enum": [
            "int8",
            "int16",
            "int32",
            "float16",
            "float32",
            "float64",
            "implementation_defined"
          ]
        },
        "memory_budget_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "max_compute_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "degradedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when_missing",
        "fallback",
        "effect"
      ],
      "properties": {
        "when_missing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          }
        },
        "fallback": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      }
    },
    "degradedOperationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_required_inputs"
      ],
      "properties": {
        "minimum_required_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/degradedRule"
          }
        },
        "confidence_reporting": {
          "type": "boolean"
        }
      }
    },
    "artifactsDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reference_runtime": {
          "type": "string"
        },
        "test_vectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "traceabilityDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author",
        "organization",
        "created",
        "last_modified"
      ],
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "type": "string",
          "minLength": 1
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "last_modified": {
          "type": "string",
          "format": "date"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}